function A = localAlpha(map,thr,alphaMin,alphaMax,clim)
map = double(map);
absmap = abs(map);
if isempty(thr) || ~isfinite(thr), thr = 0; end
lo = alphaMin; hi = alphaMax;
if ~isfinite(lo), lo = 10; end
if ~isfinite(hi) || hi <= lo, hi = lo + 10; end
den = max(eps,hi-lo);
A = (absmap - lo) ./ den;
A = max(0,min(1,A));
A(absmap < thr) = 0;
A(~isfinite(map)) = 0;
end

function x = localNormalize01(x)
x = double(x);
x(~isfinite(x)) = 0;
mn = localPrctile(x(:),1);
mx = localPrctile(x(:),99);
if mx <= mn
    mn = min(x(:)); mx = max(x(:));
end
if mx > mn
    x = (x-mn)/(mx-mn);
else
    x = zeros(size(x));
end
x = max(0,min(1,x));
end

function cm = localCmap(name,n)
if nargin < 2, n = 256; end
name = lower(char(name));
switch name
    case {'hot'}
        cm = hot(n);
    case {'jet'}
        cm = jet(n);
    case {'gray','grey'}
        cm = gray(n);
    case {'winter'}
        cm = winter(n);
    case {'parula'}
        try, cm = parula(n); catch, cm = jet(n); end
    case {'turbo'}
        try, cm = turbo(n); catch, cm = jet(n); end
    otherwise
        % blackbody-style: black -> red -> orange/yellow -> white
        x = linspace(0,1,n)';
        r = min(1,3*x);
        g = min(1,max(0,3*x-1));
        b = min(1,max(0,3*x-2));
        cm = [r g b];
end
end

function p = localPrctile(x,q)
x = double(x(:));
x = x(isfinite(x));
if isempty(x), p = 0; return; end
x = sort(x);
idx = 1 + (numel(x)-1) * q/100;
lo = floor(idx); hi = ceil(idx);
lo = max(1,min(numel(x),lo));
hi = max(1,min(numel(x),hi));
if lo == hi
    p = x(lo);
else
    p = x(lo) + (idx-lo)*(x(hi)-x(lo));
end
end

function localSetStatus(fig,msg)
fprintf('%s\n',msg);
if isempty(fig) || ~ishghandle(fig), return; end
try
    objs = findall(fig,'Style','text');
    best = [];
    for i = 1:numel(objs)
        s = lower(localGetProp(objs(i),'String'));
        tg = lower(localGetProp(objs(i),'Tag'));
        if ~isempty(strfind(s,'group map analysis')) || ~isempty(strfind(s,'status')) || ~isempty(strfind(tg,'status'))
            best = objs(i);
            break;
        end
    end
    if ~isempty(best) && ishghandle(best)
        set(best,'String',msg);
        drawnow;
    end
catch
end
end

function s = localGetProp(h,p)
s = '';
try
    v = get(h,p);
    if ischar(v), s = v;
    elseif isnumeric(v), s = num2str(v);
    elseif iscell(v), s = strjoin(v,' ');
    else, s = char(v);
    end
catch
end
end

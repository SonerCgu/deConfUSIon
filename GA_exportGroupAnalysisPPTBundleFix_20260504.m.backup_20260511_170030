function out = GA_exportGroupAnalysisPPTBundleFix_20260504(mode,varargin)
% GA_exportGroupAnalysisPPTBundleFix_20260504
% Robust GroupAnalysis export hotfix.
% Modes:
%   GA_exportGroupAnalysisPPTBundleFix_20260504('ppt')
%   GA_exportGroupAnalysisPPTBundleFix_20260504('scm')

if nargin < 1 || isempty(mode), mode = 'ppt'; end
out = [];
fig = localGetFigure(varargin{:});

try
    switch lower(char(mode))
        case {'ppt','powerpoint','exportppt'}
            out = localExportPPT(fig);
        case {'scm','data','exportdata','bundle'}
            out = localExportSCM(fig);
        otherwise
            error('Unknown mode: %s',char(mode));
    end
catch ME
    localSetStatus(fig,['Export ERROR: ' ME.message]);
    fprintf(2,'\nExport ERROR: %s\n',ME.message);
    rethrow(ME);
end
end

function fig = localGetFigure(varargin)
fig = [];
for k = 1:numel(varargin)
    try
        if ishghandle(varargin{k})
            fig = ancestor(varargin{k},'figure');
            if ~isempty(fig), return; end
        end
    catch
    end
end
try
    figs = findall(0,'Type','figure');
    for k = 1:numel(figs)
        nm = lower(localGetProp(figs(k),'Name'));
        tg = lower(localGetProp(figs(k),'Tag'));
        if ~isempty(strfind(nm,'group')) || ~isempty(strfind(tg,'group'))
            fig = figs(k);
            return;
        end
    end
end
try, fig = gcf; catch, fig = []; end
end

function out = localExportPPT(fig)
if isempty(fig) || ~ishghandle(fig)
    error('Open GroupAnalysis first, then run the exporter.');
end

localSetStatus(fig,'Export PPT: collecting open GroupAnalysis data ...');
S = localCollectState(fig);
D = localPickMainArray(S);
if isempty(D.data)
    error(['Could not find group PSC / time-series / map-stack data in the open GUI. ' ...
           'Run Group Map Analysis first, keep the GroupAnalysis window open, then export again.']);
end

info = localInferInfo(S,D);
pr = localSmallPrompt(info);
if isempty(pr)
    localSetStatus(fig,'Export PPT cancelled.');
    out = [];
    return;
end

[saveFile,savePath] = uiputfile('*.pptx','Save GroupAnalysis PPT export',fullfile(pwd,'GroupAnalysis_PI_export.pptx'));
if isequal(saveFile,0)
    localSetStatus(fig,'Export PPT cancelled.');
    out = [];
    return;
end
pptFile = fullfile(savePath,saveFile);
pngDir = fullfile(savePath,['GA_export_png_' datestr(now,'yyyymmdd_HHMMSS')]);
if ~exist(pngDir,'dir'), mkdir(pngDir); end

localSetStatus(fig,'Export PPT: preparing PI-windowed brain maps ...');

[maps,labels,usedMode] = localBuildMaps(D.data,info.TR,pr.piStart,pr.piEnd,pr.winSize);
if isempty(maps)
    error('No maps could be generated. Check PI window and window size.');
end

bg = localPickBackground(S,size(maps));
clim = info.caxis;
thr = info.threshold;
alphaMin = info.alphaMin;
alphaMax = info.alphaMax;
cmapName = info.cmap;

nMaps = size(maps,3);
pngs = cell(nMaps,1);
for k = 1:nMaps
    localSetStatus(fig,sprintf('Export PPT: rendering brain %d / %d ...',k,nMaps));
    thisBg = localBgForIndex(bg,k,size(maps(:,:,k)));
    pngs{k} = fullfile(pngDir,sprintf('GA_PI_brain_%03d.png',k));
    localRenderBrainPNG(thisBg,maps(:,:,k),pngs{k},labels{k},clim,thr,alphaMin,alphaMax,cmapName);
end

cbFile = fullfile(pngDir,'GA_left_colorbar.png');
localRenderColorbarPNG(cbFile,clim,cmapName);

meta = localMakeMetaText(S,D,info,pr,usedMode,nMaps);
localSetStatus(fig,'Export PPT: creating PowerPoint ...');
localWritePPT(pptFile,pngs,labels,cbFile,meta,pr.perSlide);

localSetStatus(fig,['Export PPT complete: ' pptFile]);
fprintf('\nExport PPT complete:\n%s\n',pptFile);
out = pptFile;
end


function U = localPickFastUnderlay(S,sz)
U = [];
paths = {'lastMAP.commonUnderlay','lastMAP.underlay','lastMAP.bg','lastMAP.brainImage', ...
    'lastMapDisplay.underlay','lastMapDisplay.bg','commonUnderlay','underlay2D','underlay','brainImage','bg','U'};
for i = 1:numel(paths)
    v = localGetPath(S,paths{i});
    if isnumeric(v) && ~isempty(v) && numel(v) > 25
        U = v; break;
    end
end
if isempty(U), U = zeros(sz); end
U = double(U);
if ndims(U) > 3, U = squeeze(U); end
if ndims(U) == 3 && size(U,3) ~= 3, U = U(:,:,1); end
U(~isfinite(U)) = 0;
end

function B = localResizeLike(A,sz)
if numel(sz) > 2, sz = sz(1:2); end
A = double(A);
if ndims(A) == 3 && size(A,3) == 3
    B = zeros(sz(1),sz(2),3);
    for c = 1:3, B(:,:,c) = localResizeLike(A(:,:,c),sz); end
    return;
end
if ndims(A) > 2, A = squeeze(A); if ndims(A) > 2, A = A(:,:,1); end, end
if isequal(size(A),sz), B = A; return; end
try
    B = imresize(A,sz,'bilinear');
catch
    [Y,X] = size(A);
    [xq,yq] = meshgrid(linspace(1,X,sz(2)),linspace(1,Y,sz(1)));
    B = interp2(double(A),xq,yq,'linear',0);
end
end

function img = localFirstImage(A)
A = squeeze(double(A));
if ndims(A) == 2
    img = A;
elseif ndims(A) == 3
    if size(A,3) == 3 && localLooksRGB(A), img = localGray(A); else, img = A(:,:,1); end
else
    img = squeeze(A(:,:,ceil(size(A,3)/2),1));
end
end

function tf = localLooksRGB(A)
tf = false;
try
    tf = ndims(A) == 3 && size(A,3) == 3 && min(A(:)) >= 0 && max(A(:)) <= 255;
catch
end
end

function T = localGuessT(A)
A = squeeze(A); d = ndims(A); sz = size(A);
if d <= 2
    T = 1;
elseif d == 3
    if sz(3) == 3 && localLooksRGB(A), T = 1; else, T = sz(3); end
else
    if sz(3) > 10 && sz(4) <= 50
        T = sz(3);
    else
        T = sz(end);
    end
end
end

function cax = localAutoCaxisFromData(A)
x = double(A(:)); x = x(isfinite(x));
if isempty(x), cax = [0 100]; return; end
lo = localPrctile(x,2); hi = localPrctile(x,98);
if lo == hi, lo = min(x); hi = max(x); end
if lo == hi, lo = 0; hi = 1; end
if lo > 0, lo = 0; end
cax = [lo hi];
end

function cax = localAxesCaxis(hFig)
cax = [];
try
    axs = findall(hFig,'Type','axes');
    for i = 1:numel(axs)
        cl = get(axs(i),'CLim');
        if isnumeric(cl) && numel(cl) == 2 && all(isfinite(cl)) && cl(1) ~= cl(2)
            if ~(cl(1) == 0 && cl(2) == 1)
                cax = cl; return;
            end
        end
    end
catch
end
end

function q = localPrctile(x,p)
x = sort(double(x(:))); x = x(isfinite(x));
if isempty(x), q = 0; return; end
pos = 1 + (numel(x)-1)*p/100;
lo = floor(pos); hi = ceil(pos);
if lo == hi, q = x(lo); else, q = x(lo) + (x(hi)-x(lo))*(pos-lo); end
end

function v = localGetPath(S,path)
v = [];
parts = regexp(path,'\.','split'); cur = S;
for i = 1:numel(parts)
    if isstruct(cur) && isfield(cur,parts{i})
        cur = cur.(parts{i});
    else
        return;
    end
end
v = cur;
end

function x = localNamedField(S,names)
x = [];
if ~isstruct(S), return; end
f = fieldnames(S);
for i = 1:numel(f)
    for j = 1:numel(names)
        if strcmpi(f{i},names{j}), x = S.(f{i}); return; end
    end
end
for i = 1:numel(f)
    y = S.(f{i});
    if isstruct(y) && numel(y) == 1
        ff = fieldnames(y);
        for k = 1:numel(ff)
            for j = 1:numel(names)
                if strcmpi(ff{k},names{j}), x = y.(ff{k}); return; end
            end
        end
    end
end
end

function v = localNumSetting(S,names,fb)
v = fb; x = localNamedField(S,names);
try
    if ischar(x), x = str2double(x); end
    if iscell(x), x = x{1}; end
    x = double(x); x = x(isfinite(x));
    if ~isempty(x), v = x(1); end
catch
end
end

function v = localVecSetting(S,names,fb)
v = fb; x = localNamedField(S,names);
try
    if ischar(x), x = sscanf(x,'%f'); end
    x = double(x); x = x(isfinite(x));
    if numel(x) >= 2, v = x(1:2)'; end
catch
end
end

function s = localCharSetting(S,names,fb)
s = fb; x = localNamedField(S,names);
try
    if iscell(x), x = x{1}; end
    if ~isempty(x), s = strtrim(char(x)); end
catch
end
end

function v = localNumFromUI(hFig,keys,fb)
v = fb;
try
    edits = findall(hFig,'Style','edit');
    for i = 1:numel(edits)
        tag = lower(char(get(edits(i),'Tag')));
        str = char(get(edits(i),'String'));
        hit = false;
        for k = 1:numel(keys)
            if ~isempty(strfind(tag,lower(keys{k}))), hit = true; end
        end
        if hit
            q = str2double(str);
            if isfinite(q), v = q; return; end
        end
    end
catch
end
end

function subjects = localPickSubjects(S)

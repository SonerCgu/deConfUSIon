function localDlgOK(d,h,auto)
try
    cfg = auto;
    cfg.injStart = str2double(get(h{1},'String'));
    cfg.injEnd = str2double(get(h{2},'String'));
    cfg.exportStart = str2double(get(h{3},'String'));
    cfg.exportEnd = str2double(get(h{4},'String'));
    cfg.windowSize = str2double(get(h{5},'String'));
    cfg.mapsPerSlide = round(str2double(get(h{6},'String')));
    if ~isfinite(cfg.injStart), cfg.injStart = 0; end
    if ~isfinite(cfg.injEnd), cfg.injEnd = 300; end
    if ~isfinite(cfg.exportStart), cfg.exportStart = cfg.injStart; end
    if ~isfinite(cfg.exportEnd), cfg.exportEnd = cfg.duration; end
    if cfg.exportEnd <= cfg.exportStart, error('Export end must be after export start.'); end
    if ~isfinite(cfg.windowSize) || cfg.windowSize <= 0, error('Window size must be positive.'); end
    if ~isfinite(cfg.mapsPerSlide) || cfg.mapsPerSlide < 1, cfg.mapsPerSlide = 6; end
    cfg.created = datestr(now);
    setappdata(d,'cfg',cfg);
    uiresume(d);
catch ME
    errordlg(ME.message,'Invalid export settings');
end
end

function [TS,U] = localPrepareTS(rawTS,U,cfg)
A = double(rawTS);
A(~isfinite(A)) = 0;
A = squeeze(A);
d = ndims(A);

if d == 2
    TS = reshape(A,[size(A,1) size(A,2) 1]);
elseif d == 3
    if size(A,3) == 3 && localLooksRGB(A)
        TS = reshape(localGray(A),[size(A,1) size(A,2) 1]);
    else
        TS = A;
    end
elseif d == 4
    sz = size(A);
    if sz(3) > 10 && sz(4) <= 50
        % likely Y x X x T x subject/group: average last dimension
        TS = mean(A,4);
    else
        % likely Y x X x Z x T: use middle Z slice, not slice 1
        z = cfg.sliceIndex;
        if ~isfinite(z) || z <= 0, z = ceil(sz(3)/2); end
        z = max(1,min(sz(3),round(z)));
        TS = squeeze(A(:,:,z,:));
    end
else
    sz = size(A);
    A = reshape(A,sz(1),sz(2),prod(sz(3:end-1)),sz(end));
    z = ceil(size(A,3)/2);
    TS = squeeze(A(:,:,z,:));
end

if ndims(TS) < 3
    TS = reshape(TS,[size(TS,1) size(TS,2) 1]);
end
U = localResizeLike(U,size(TS(:,:,1)));
end

function [maps,winInfo] = localWindowMaps(TS,cfg)
T = size(TS,3);
t = (0:T-1) .* cfg.TR;
maps = [];
winInfo = struct('startSec',{},'endSec',{},'relStartSec',{},'relEndSec',{},'frameIdx',{},'label',{});

if T <= 1
    maps(:,:,1) = TS(:,:,1);
    wi.startSec = cfg.exportStart;
    wi.endSec = cfg.exportEnd;
    wi.relStartSec = cfg.exportStart - cfg.injStart;
    wi.relEndSec = cfg.exportEnd - cfg.injStart;
    wi.frameIdx = 1;
    wi.label = localPILabel(wi.relStartSec,wi.relEndSec);
    winInfo = wi;
    return;
end

starts = cfg.exportStart:cfg.windowSize:(cfg.exportEnd-eps);
if isempty(starts), starts = cfg.exportStart; end

for k = 1:numel(starts)
    st = starts(k);
    en = min(st + cfg.windowSize,cfg.exportEnd);
    idx = find(t >= st & t < en);
    idx = idx(idx >= 1 & idx <= T);
    if isempty(idx)
        % Safe partial-window fallback, clipped to available frames.
        i1 = max(1,min(T,floor(st ./ cfg.TR) + 1));
        i2 = max(1,min(T,ceil(en ./ cfg.TR)));
        if i2 >= i1 && st < (T .* cfg.TR)
            idx = i1:i2;
        end
    end
    idx = idx(idx >= 1 & idx <= T);
    if isempty(idx)
        continue;
    end
    maps(:,:,end+1) = localMean3(TS(:,:,idx)); %#ok<AGROW>
    wi.startSec = st;
    wi.endSec = en;
    wi.relStartSec = st - cfg.injStart;
    wi.relEndSec = en - cfg.injStart;
    wi.frameIdx = idx(:)';
    wi.label = localPILabel(wi.relStartSec,wi.relEndSec);
    winInfo(end+1) = wi; %#ok<AGROW>
end
end

function s = localPILabel(a,b)
if a >= 0 && b >= 0
    s = sprintf('PI +%.0f-%.0f s',a,b);
elseif a < 0 && b <= 0
    s = sprintf('Pre %.0f-%.0f s',a,b);
else
    s = sprintf('PI %.0f-%.0f s',a,b);
end
end

function m = localMean3(A)
if ndims(A) == 2
    m = A;
else
    m = mean(A,3);
end
m(~isfinite(m)) = 0;
end

function localExportPPT(hFig,S,TS,U,maps,winInfo,subjects,info,cfg)
startDir = localStartDir(S);
[f,p] = uiputfile({'*.pptx','PowerPoint (*.pptx)'},'Save GroupAnalysis PPT', ...
    fullfile(startDir,['GroupAnalysis_TimeSeries_' datestr(now,'yyyymmdd_HHMMSS') '.pptx']));
if isequal(f,0)
    localStatus(hFig,'Export PPT cancelled.');
    return;
end
pptFile = fullfile(p,f);
[~,baseName] = fileparts(pptFile);
pngDir = fullfile(p,[baseName '_PNGs']);
if exist(pngDir,'dir') ~= 7, mkdir(pngDir); end

slidePNGs = {};
localStatus(hFig,'Export PPT: summary slide ...');
summaryPNG = fullfile(pngDir,'slide_001_summary.png');
localSummarySlide(summaryPNG,cfg,subjects,info,TS,maps,winInfo);
slidePNGs{end+1} = summaryPNG;

nMaps = size(maps,3);
perSlide = max(1,cfg.mapsPerSlide);
nSlides = ceil(nMaps/perSlide);
for s = 1:nSlides
    idx1 = (s-1)*perSlide + 1;
    idx2 = min(nMaps,s*perSlide);
    localStatus(hFig,sprintf('Export PPT: slide %d/%d, windows %d-%d ...',s,nSlides,idx1,idx2));
    pngFile = fullfile(pngDir,sprintf('slide_%03d_maps.png',s+1));
    localGridSlide(pngFile,maps(:,:,idx1:idx2),U,cfg,winInfo(idx1:idx2),subjects,s,nSlides);
    slidePNGs{end+1} = pngFile;
end

localStatus(hFig,'Export PPT: writing pptx ...');
localWritePPT(pptFile,slidePNGs);
save(fullfile(pngDir,'export_settings.mat'),'cfg','subjects','info','winInfo','maps','U','-v7.3');
localStatus(hFig,['Export PPT complete: ' pptFile]);
fprintf('\nExport PPT complete:\n%s\n',pptFile);
end

function localExportData(hFig,S,TS,U,maps,winInfo,subjects,info,cfg)
startDir = localStartDir(S);
[f,p] = uiputfile({'*.mat','MAT-file (*.mat)'},'Save SCM-compatible GroupAnalysis data', ...
    fullfile(startDir,['GroupAnalysis_SCM_TimeSeries_' datestr(now,'yyyymmdd_HHMMSS') '.mat']));
if isequal(f,0)
    localStatus(hFig,'Export Data SCM cancelled.');
    return;
end
outFile = fullfile(p,f);
localStatus(hFig,'Export Data SCM: rendering overlays ...');
nMaps = size(maps,3);
renderedRGB = cell(1,nMaps);
alphaMasks = cell(1,nMaps);
for k = 1:nMaps
    [renderedRGB{k},alphaMasks{k}] = localRender(maps(:,:,k),U,cfg);
end
PSC = reshape(double(TS),[size(TS,1) size(TS,2) 1 size(TS,3)]);
TR = cfg.TR;
tsec = (0:size(TS,3)-1).*TR;
tmin = tsec./60;
bg = U; underlay2D = U; commonUnderlay = U; brainImage = U;
windowMaps = maps; scmMapAtlas = maps; overlay2D = maps(:,:,1); groupMap2D = maps(:,:,1);
par = struct(); par.source = 'GroupAnalysis'; par.exportType = 'SCM-compatible time-series group export'; par.cfg = cfg;
G = struct();
G.created = datestr(now); G.source = 'GroupAnalysis Export Data SCM fast'; G.isGroupAnalysis = true;
G.subjects = subjects; G.info = info; G.cfg = cfg; G.winInfo = winInfo;
G.PSC = PSC; G.TS = TS; G.windowMaps = windowMaps; G.underlay2D = underlay2D;
G.commonUnderlay = commonUnderlay; G.bg = bg; G.brainImage = brainImage;
G.renderedRGB = renderedRGB; G.alphaMasks = alphaMasks; G.TR = TR; G.tsec = tsec; G.tmin = tmin; G.par = par;
GA = G;
save(outFile,'G','GA','PSC','TS','windowMaps','winInfo','underlay2D','commonUnderlay', ...
    'brainImage','bg','overlay2D','groupMap2D','scmMapAtlas','renderedRGB','alphaMasks', ...
    'TR','tsec','tmin','par','cfg','subjects','info','-v7.3');
localStatus(hFig,['Export Data SCM complete: ' outFile]);
fprintf('\nExport Data SCM complete:\n%s\n',outFile);
end


    try
        x = localGetPath(S,k{1});
        if ischar(x) && exist(x,'dir') == 7, out = x; return; end
    catch
    end
end
end

function localStatus(hFig,msg)
msg = char(msg);
try, set(hFig,'Name',msg); catch, end
try
    txt = findall(hFig,'Style','text');
    for i = 1:numel(txt)
        try
            s = get(txt(i),'String');
            if iscell(s), s = s{1}; end
            low = lower(char(s));
            if ~isempty(strfind(low,'group map')) || ~isempty(strfind(low,'complete')) || ~isempty(strfind(low,'status')) || ~isempty(strfind(low,'export'))
                set(txt(i),'String',msg,'ForegroundColor',[1 0.9 0.25]);
            end
        catch
        end
    end
catch
end
drawnow;
fprintf('[GroupAnalysis export] %s\n',msg);
end

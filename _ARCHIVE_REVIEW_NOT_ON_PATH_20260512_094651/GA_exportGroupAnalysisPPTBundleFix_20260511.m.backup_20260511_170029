function localGridSlide(pngFile,maps,U,cfg,winInfo,subjects,slideNum,nSlides)
n = size(maps,3);
[~,~,cmap] = localRender(maps(:,:,1),U,cfg);
fig = figure('Visible','off','Color','k','Units','pixels','Position',[100 100 1600 900]);
tax = axes('Parent',fig,'Position',[0 0 1 1]); axis(tax,'off');
text(tax,0.035,0.955,sprintf('GroupAnalysis Time Series  |  Slide %d / %d',slideNum,nSlides), ...
    'Color','w','FontSize',21,'FontWeight','bold','Interpreter','none');
text(tax,0.965,0.955,sprintf('n = %d',numel(subjects)), ...
    'Color',[0.85 0.85 0.85],'FontSize',13,'HorizontalAlignment','right','Interpreter','none');

cbax = axes('Parent',fig,'Position',[0.045 0.22 0.030 0.55]);
grad = linspace(cfg.caxis(2),cfg.caxis(1),256)';
imagesc(cbax,grad); colormap(cbax,cmap);
set(cbax,'XTick',[],'YTick',[1 128 256], ...
    'YTickLabel',{num2str(cfg.caxis(2)),num2str(mean(cfg.caxis)),num2str(cfg.caxis(1))}, ...
    'YAxisLocation','left','Color','k','XColor','w','YColor','w','FontSize',12);
title(cbax,'PSC','Color','w','FontSize',13,'Interpreter','none');

cols = 3; rows = 2;
if n <= 4, cols = 2; rows = 2; end
x0 = 0.13; xGap = 0.025; yGap = 0.065;
w = (0.83 - (cols-1)*xGap) / cols;
h = (0.76 - (rows-1)*yGap) / rows;
for i = 1:n
    r = floor((i-1)/cols); c = mod(i-1,cols);
    x = x0 + c*(w+xGap);
    y = 0.13 + (rows-1-r)*(h+yGap);
    ax = axes('Parent',fig,'Position',[x y w h]);
    rgb = localRender(maps(:,:,i),U,cfg);
    image(ax,rgb); axis(ax,'image'); axis(ax,'off');
    wi = winInfo(i);
    title(ax,sprintf('%s  |  %.0f-%.0f s',wi.label,wi.startSec,wi.endSec), ...
        'Color','w','FontSize',13,'FontWeight','bold','Interpreter','none');
    if ~isempty(wi.frameIdx)
        text(ax,0.02,0.05,sprintf('frames %d-%d',wi.frameIdx(1),wi.frameIdx(end)), ...
            'Units','normalized','Color',[1 0.9 0.25],'FontSize',10,'FontWeight','bold','Interpreter','none');
    end
end
text(tax,0.50,0.025,sprintf('PI %.0f-%.0f s  |  window %.0f s  |  caxis [%g %g]', ...
    cfg.injStart,cfg.injEnd,cfg.windowSize,cfg.caxis(1),cfg.caxis(2)), ...
    'Color',[0.75 0.75 0.75],'FontSize',12,'HorizontalAlignment','center','Interpreter','none');
localPrintPNG(fig,pngFile);
close(fig);
end

function [rgb,alpha,cmap] = localRender(M,U,cfg)
M = double(M); M(~isfinite(M)) = 0;
U = localResizeLike(U,size(M));
base = localBaseRGB(U);
cmap = localCmap(cfg.colormapName,256);
cax = cfg.caxis;
if isempty(cax) || numel(cax) < 2 || cax(1) == cax(2)
    cax = localAutoCaxisFromData(M);
end
idx = round(1 + 255 .* (M - cax(1)) ./ max(eps,(cax(2)-cax(1))));
idx(idx < 1) = 1; idx(idx > 256) = 256;
ov = ind2rgb(idx,cmap);
pass = abs(M) >= cfg.threshold;
alpha = (abs(M) - cfg.modMin) ./ max(eps,(cfg.modMax-cfg.modMin));
alpha(~pass) = 0; alpha(~isfinite(alpha)) = 0;
alpha(alpha < 0) = 0; alpha(alpha > 1) = 1;
a3 = repmat(alpha,[1 1 3]);
rgb = base.*(1-a3) + ov.*a3;
rgb(rgb < 0) = 0; rgb(rgb > 1) = 1;
end

function base = localBaseRGB(U)
if ndims(U) == 3 && size(U,3) == 3
    base = double(U);
    if max(base(:)) > 1, base = base./255; end
else
    g = localGray(U);
    base = repmat(g,[1 1 3]);
end
base(base < 0) = 0; base(base > 1) = 1;
end

function g = localGray(A)
A = double(A);
if ndims(A) == 3 && size(A,3) == 3
    A = 0.2989*A(:,:,1) + 0.5870*A(:,:,2) + 0.1140*A(:,:,3);
end
A(~isfinite(A)) = 0;
mn = min(A(:)); mx = max(A(:));
if mx > mn, g = (A-mn)./(mx-mn); else, g = zeros(size(A)); end
end

function cmap = localCmap(name,n)
if nargin < 2, n = 256; end
name = lower(strtrim(char(name)));
try
    switch name
        case {'blackbdy_iso','blackbdy','blackbody'}
            cmap = hot(n).^0.85;
        case 'hot'
            cmap = hot(n);
        case 'gray'
            cmap = gray(n);
        case 'jet'
            cmap = jet(n);
        case 'parula'
            cmap = parula(n);
        case 'turbo'
            try, cmap = turbo(n); catch, cmap = parula(n); end
        case 'winter'
            cmap = winter(n);
        case 'bone'
            cmap = bone(n);
        case 'copper'
            cmap = copper(n);
        otherwise
            cmap = hot(n).^0.85;
    end
catch
    cmap = hot(n);
end
end

function localWritePPT(pptFile,slidePNGs)
if exist(pptFile,'file') == 2
    try, delete(pptFile); catch, end
end
if ~isempty(which('mlreportgen.ppt.Presentation'))
    import mlreportgen.ppt.*
    ppt = Presentation(pptFile); open(ppt);
    for i = 1:numel(slidePNGs)
        slide = add(ppt,'Blank');
        pic = Picture(slidePNGs{i});
        pic.X = '0in'; pic.Y = '0in'; pic.Width = '13.333in'; pic.Height = '7.5in';
        add(slide,pic);
    end
    close(ppt);
elseif ispc && exist('actxserver','file') == 2
    app = actxserver('PowerPoint.Application');
    app.Visible = 1;
    pres = app.Presentations.Add;
    pres.PageSetup.SlideWidth = 960; pres.PageSetup.SlideHeight = 540;
    for i = 1:numel(slidePNGs)
        slide = pres.Slides.Add(i,12);
        slide.FollowMasterBackground = 0;
        slide.Background.Fill.ForeColor.RGB = 0;
        slide.Shapes.AddPicture(slidePNGs{i},0,1,0,0,960,540);
    end
    pres.SaveAs(pptFile); pres.Close; app.Quit;
else
    error('No PPT writer found. Need mlreportgen.ppt or PowerPoint COM.');
end
if exist(pptFile,'file') ~= 2
    error('PPT was not created: %s',pptFile);
end
end


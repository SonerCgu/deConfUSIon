function c = localToCellstr(x)
c = {};
try
    if isempty(x), return; end
    if iscell(x), c = cellfun(@char,x(:),'UniformOutput',false);
    elseif ischar(x), c = cellstr(x);
    elseif isnumeric(x), c = arrayfun(@(q)sprintf('%g',q),x(:),'UniformOutput',false);
    else, return;
    end
    c = c(:)';
catch
    c = {};
end
end

function s = localJoin(c,sep)
if isempty(c), s = ''; return; end
s = char(c{1});
for i = 2:numel(c), s = [s sep char(c{i})]; end
end

function out = localStartDir(S)
out = pwd;

function GA_exportGroupAnalysisPPTBundleFix_20260511(hFig,mode)
% Fast SCM-style GroupAnalysis exporter.
% No deep recursive GUI scan. Small popup only. MATLAB 2017b compatible.

if nargin < 1 || isempty(hFig) || ~ishghandle(hFig)
    try, hFig = gcbf; catch, hFig = []; end
end
if isempty(hFig) || ~ishghandle(hFig)
    try, hFig = gcf; catch, hFig = []; end
end
if isempty(hFig) || ~ishghandle(hFig)
    error('No valid GroupAnalysis figure found.');
end
try
    if ~strcmpi(get(hFig,'Type'),'figure')
        hFig = ancestor(hFig,'figure');
    end
catch
end

if nargin < 2 || isempty(mode)
    mode = 'ppt';
end
if isnumeric(mode) || islogical(mode)
    if logical(mode(1)), mode = 'ppt'; else, mode = 'data'; end
end
mode = lower(strtrim(char(mode)));

S = guidata(hFig);
if isempty(S) || ~isstruct(S)
    error('Could not read GroupAnalysis GUI state. Run/preview the group map first.');
end

try
    localStatus(hFig,'Export: fast data lookup ...');
    [rawTS,U,subjects,info,auto] = localCollectFast(hFig,S);
    cfg = localSmallDialog(auto,rawTS);
    if isempty(cfg)
        localStatus(hFig,'Export cancelled.');
        return;
    end
    [TS,U] = localPrepareTS(rawTS,U,cfg);
    [maps,winInfo] = localWindowMaps(TS,cfg);
    if isempty(maps)
        error('No export windows were generated. Check TR, export start/end, and window size.');
    end
    if isempty(cfg.caxisAuto)
        cfg.caxis = localAutoCaxisFromData(maps);
    else
        cfg.caxis = cfg.caxisAuto;
    end
    switch mode
        case {'ppt','powerpoint','exportppt'}
            localExportPPT(hFig,S,TS,U,maps,winInfo,subjects,info,cfg);
        case {'data','scm','exportdata','exportdatascm'}
            localExportData(hFig,S,TS,U,maps,winInfo,subjects,info,cfg);
        otherwise
            error('Unknown export mode: %s',mode);
    end
catch ME
    localStatus(hFig,['Export failed: ' ME.message]);
    rethrow(ME);
end
end

function [rawTS,U,subjects,info,auto] = localCollectFast(hFig,S)
rawTS = localPickFastTimeSeries(S);
if isempty(rawTS)
    rawTS = localPickFastStaticMap(S);
    if isempty(rawTS)
        error('No GroupAnalysis PSC/time-series/map found. Run/preview the group map first, then export.');
    end
end
raw2D = localFirstImage(rawTS);
U = localPickFastUnderlay(S,size(raw2D));
U = localResizeLike(U,size(raw2D));
subjects = localPickSubjects(S);
info = struct();
info.created = datestr(now);
info.subjects = subjects;
info.nSubjects = numel(subjects);
info.analysisName = localCharSetting(S,{'analysisName','tag','fileLabel','title'},'GroupAnalysis');
auto = localAutoSettings(hFig,S,rawTS);
end

function rawTS = localPickFastTimeSeries(S)
rawTS = [];
paths = { ...
    'lastMAP.PSC','lastMAP.groupPSC','lastMAP.meanPSC','lastMAP.TS','lastMAP.timeSeries', ...
    'lastMapDisplay.PSC','lastMapDisplay.groupPSC','lastMapDisplay.TS','lastMapDisplay.timeSeries', ...
    'G.PSC','GA.PSC','G.TS','GA.TS', ...
    'PSC','groupPSC','meanPSC','pscMean','TS','timeSeries','groupTimeSeries'};
for i = 1:numel(paths)
    v = localGetPath(S,paths{i});
    if localIsTS(v)
        rawTS = v;
        return;
    end
end

% Fast shallow scan only: top level and one struct level. No deep recursion through handles.
rawTS = localShallowNumericSearch(S,{'psc','timeseries','timeSeries','groupPSC','meanPSC','TS'},true);
end

function M = localPickFastStaticMap(S)
M = [];
paths = { ...
    'lastMAP.groupMap','lastMAP.map','lastMAP.overlay','lastMAP.M', ...
    'lastMapDisplay.groupMap','lastMapDisplay.map','lastMapDisplay.overlay', ...
    'groupMap','groupMap2D','scmMapAtlas','mapAtlas','overlay2D','overlay','map'};
for i = 1:numel(paths)
    v = localGetPath(S,paths{i});
    if isnumeric(v) && ~isempty(v) && numel(v) > 25
        M = v;
        return;
    end
end
M = localShallowNumericSearch(S,{'groupmap','map','overlay','scmmap'},false);
end

function v = localShallowNumericSearch(S,keys,wantTS)
v = []; bestScore = -Inf;
if ~isstruct(S), return; end
f = fieldnames(S);
for i = 1:numel(f)
    x = S.(f{i});
    [hit,score] = localNameHit(f{i},keys);
    if hit && isnumeric(x) && numel(x) > 25
        ok = true;
        if wantTS, ok = localIsTS(x); end
        if ok && score > bestScore
            bestScore = score; v = x;
        end
    end
    if isstruct(x) && numel(x) == 1
        ff = fieldnames(x);
        for j = 1:numel(ff)
            y = x.(ff{j});
            [hit2,score2] = localNameHit(ff{j},keys);
            if hit2 && isnumeric(y) && numel(y) > 25
                ok = true;
                if wantTS, ok = localIsTS(y); end
                if ok && score2+10 > bestScore
                    bestScore = score2+10; v = y;
                end
            end
        end
    end
end
end

function [hit,score] = localNameHit(name,keys)
n = lower(char(name)); hit = false; score = 0;
for k = 1:numel(keys)
    kk = lower(char(keys{k}));
    if ~isempty(strfind(n,kk))
        hit = true; score = score + 50 + numel(kk);
    end
end
bad = {'button','panel','axis','axes','handle','text','table'};
for k = 1:numel(bad)
    if ~isempty(strfind(n,bad{k}))
        score = score - 200;
    end
end
end

function tf = localIsTS(v)
tf = false;
if ~isnumeric(v) || isempty(v) || numel(v) < 50, return; end
v = squeeze(v);
d = ndims(v); sz = size(v);
if d < 3, return; end
if d == 3 && sz(3) == 3 && localLooksRGB(v), return; end
if d == 3 && sz(3) >= 2, tf = true; return; end
if d >= 4 && sz(end) >= 2, tf = true; return; end
end

function auto = localAutoSettings(hFig,S,rawTS)
T = localGuessT(rawTS);
TR = localNumSetting(S,{'TR','tr','TRsec','TR_s','TRms','TR_ms','repetitionTime'},NaN);
if ~isfinite(TR) || TR <= 0
    TR = localNumFromUI(hFig,{'tr','TR'},NaN);
end
if ~isfinite(TR) || TR <= 0
    TR = 1;
end
if TR > 10
    TR = TR ./ 1000;
end
dur = T .* TR;

auto = struct();
auto.TR = TR;
auto.T = T;
auto.duration = dur;
auto.injStart = localNumSetting(S,{'injStart','injectionStart','stimStart','PIstart'},0);
auto.injEnd = localNumSetting(S,{'injEnd','injectionEnd','stimEnd','PIend'},300);
if ~isfinite(auto.injEnd) || auto.injEnd <= auto.injStart
    auto.injEnd = 300;
end
auto.exportStart = auto.injStart;
auto.exportEnd = dur;
if ~isfinite(auto.exportEnd) || auto.exportEnd <= auto.exportStart
    auto.exportEnd = max(auto.injEnd,auto.exportStart+60);
end
auto.windowSize = 60;
auto.mapsPerSlide = 6;
auto.sliceIndex = 0;

cax = localVecSetting(S,{'caxis','mapCaxis','overlayCaxis','CLim','clim'},[]);
if isempty(cax)
    cax = localAxesCaxis(hFig);
end
auto.caxisAuto = cax;
auto.threshold = localNumSetting(S,{'mapThreshold','threshold','overlayThreshold','thr'},0);
auto.modMin = localNumSetting(S,{'mapModMin','modMin','alphaModMin','alphaMin'},10);
auto.modMax = localNumSetting(S,{'mapModMax','modMax','alphaModMax','alphaMax'},20);
auto.colormapName = localCharSetting(S,{'mapColormap','colormapName','overlayColormap','cmap'},'blackbdy_iso');
auto.alphaModOn = true;
end

